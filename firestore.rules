rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is a staff member
    // You could set custom claims or use a 'users' collection to verify role
    function isStaff() {
      // For the demo, we assume any user with a verified email is staff
      // or we can check a custom claim like request.auth.token.staff == true
      return request.auth != null && request.auth.token.email != null;
    }

    match /fans/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      allow read: if isStaff();
    }
    
    match /incidents/{incidentId} {
      // Fans can create incidents (via AI bot) and staff can read/update them
      allow create: if request.auth != null;
      allow read, update: if isStaff();
    }
    
    match /alerts/{alertId} {
      allow read, write: if isStaff();
    }
    
    match /stadium_state/{document=**} {
      // Anyone can read stadium state (heatmaps, queues)
      allow read: if true;
      allow write: if isStaff();
    }
  }
}
